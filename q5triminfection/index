let answered = 0;
let score = 0;

function buildQuiz() {
  const container = document.getElementById('quiz-container');
  container.innerHTML = '';
  answered = 0;
  score = 0;
  updateProgress();

  quizData.forEach((item, i) => {
    const card = document.createElement('div');
    card.className = 'q-card';
    card.id = `card-${i}`;
    card.style.animationDelay = `${i * 0.03}s`;

    const labels = ['A', 'B', 'C'];
    const optsHtml = item.opts.map((opt, j) => `
      <button class="opt-btn" onclick="select(${i},${j})" id="opt-${i}-${j}">
        <span class="opt-key">${labels[j]}</span>
        <span>${opt}</span>
      </button>`).join('');

    card.innerHTML = `
      <div class="q-header">
        <div class="q-num">Q${i+1}</div>
        <div class="q-text">${item.q}</div>
      </div>
      <div class="options">${optsHtml}</div>
      <div class="explanation" id="exp-${i}"></div>`;
    container.appendChild(card);
  });
}

function select(qIdx, optIdx) {
  const item = quizData[qIdx];
  const isCorrect = optIdx === item.ans;

  // disable all buttons
  for (let j = 0; j < 3; j++) {
    const btn = document.getElementById(`opt-${qIdx}-${j}`);
    btn.disabled = true;
    if (j === item.ans) btn.classList.add('correct');
    else if (j === optIdx && !isCorrect) btn.classList.add('wrong');
  }

  const expEl = document.getElementById(`exp-${qIdx}`);
  const verdict = isCorrect
    ? `<span class="verdict ok">✓ 正解</span>`
    : `<span class="verdict ng">✗ 不正解</span>`;
  expEl.innerHTML = `${verdict}<br>${item.exp}`;
  expEl.classList.add('show');

  document.getElementById(`card-${qIdx}`).classList.add('answered');

  if (isCorrect) score++;
  answered++;
  updateProgress();
  playSound(isCorrect);

  if (answered === quizData.length) showResult();
}

function updateProgress() {
  document.getElementById('progress-count').textContent = `${answered} / 30`;
  document.getElementById('score-display').textContent = score;
  document.getElementById('progress-fill').style.width = `${(answered/30)*100}%`;
}

function showResult() {
  const sec = document.getElementById('result-section');
  sec.classList.add('show');
  document.getElementById('final-score').textContent = score;

  let rank, label;
  if (score >= 28) { rank = 'S'; label = '🏆 パーフェクト級！感染症の専門家です'; }
  else if (score >= 24) { rank = 'A'; label = '優秀！グルーミングの現場で即戦力レベル'; }
  else if (score >= 18) { rank = 'B'; label = '良好。苦手な分野を重点復習しましょう'; }
  else if (score >= 12) { rank = 'C'; label = 'もう一度テキストを読み直すことをお勧めします'; }
  else { rank = 'D'; label = '基礎から丁寧に学び直しましょう'; }

  document.getElementById('result-rank').textContent = `RANK ${rank}`;
  document.getElementById('result-rank').className = `result-rank rank-${rank}`;
  document.getElementById('result-label').textContent = label;
  sec.scrollIntoView({ behavior: 'smooth', block: 'center' });
}

function retryQuiz() {
  document.getElementById('result-section').classList.remove('show');
  window.scrollTo({ top: 0, behavior: 'smooth' });
  setTimeout(buildQuiz, 400);
}

// Web Audio API sound
const AudioCtx = window.AudioContext || window.webkitAudioContext;
let actx;
function playSound(correct) {
  try {
    if (!actx) actx = new AudioCtx();
    const osc = actx.createOscillator();
    const gain = actx.createGain();
    osc.connect(gain); gain.connect(actx.destination);
    if (correct) {
      osc.frequency.setValueAtTime(523, actx.currentTime);
      osc.frequency.setValueAtTime(659, actx.currentTime + 0.1);
      osc.frequency.setValueAtTime(784, actx.currentTime + 0.2);
    } else {
      osc.frequency.setValueAtTime(300, actx.currentTime);
      osc.frequency.setValueAtTime(220, actx.currentTime + 0.15);
    }
    gain.gain.setValueAtTime(0.18, actx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.001, actx.currentTime + 0.4);
    osc.start(); osc.stop(actx.currentTime + 0.4);
  } catch(e) {}
}

